{
  "manifest_version": 3,
  "name": "ReTune",
  "version": "1.0.0",
  "description": "extensions by Quema",
  "icons": {
    "16": "public/retune.png",
    "48": "public/retune.png",
    "128": "public/retune.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "watch.js",
        "pitch-processor.js"
      ],
      "matches": [
        "https://www.youtube.com/*"
      ]
    }
  ]
}